+/* ================================================================
+   AUDIO CONTROL PANEL - G├│c tr├íi tr├¬n m├án h├¼nh
+   Glassmorphism AAA / z-index 50 (tr├¬n canvas, d╞░ß╗¢i modal)
+   ================================================================ */
+
+.audio-control-panel {
+  position: fixed;
+  top: 20px;
+  right: 20px;
+  left: auto;
+  z-index: 50;
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+  align-items: flex-end;
+  /* Mß║╖c ─æß╗ïnh ß║⌐n ho├án to├án khi load trang / trong game / khi xem 360 */
+  opacity: 0;
+  pointer-events: none;
+  transform: translateX(20px);
+  transition: opacity 0.25s ease, transform 0.25s ease;
+}
+
+/* Chß╗ë hiß╗ân thß╗ï duy nhß║Ñt khi ß╗ƒ Menu ch├¡nh */
+.audio-control-panel.visible-in-menu {
+  opacity: 1;
+  pointer-events: auto;
+  transform: translateX(0);
+}
+
+/* Base Audio Button */
+.audio-btn {
+  position: relative;
+  width: 48px;
+  height: 48px;
+  border-radius: 14px;
+  border: 1px solid rgba(255, 255, 255, 0.14);
+  background: rgba(12, 12, 22, 0.72);
+  backdrop-filter: blur(18px);
+  -webkit-backdrop-filter: blur(18px);
+  color: #e0e8ff;
+  cursor: pointer;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  transition: all 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
+  box-shadow:
+    0 4px 24px rgba(0, 0, 0, 0.4),
+    inset 0 1px 0 rgba(255, 255, 255, 0.08);
+  overflow: hidden;
+  flex-shrink: 0;
+}
+
+.audio-btn:hover {
+  transform: scale(1.12) translateY(-2px);
+  border-color: rgba(255, 200, 100, 0.35);
+  background: rgba(22, 22, 38, 0.88);
+  box-shadow:
+    0 8px 32px rgba(0, 0, 0, 0.5),
+    0 0 16px rgba(255, 180, 60, 0.18),
+    inset 0 1px 0 rgba(255, 255, 255, 0.12);
+  color: #fff;
+}
+
+.audio-btn:active {
+  transform: scale(0.94);
+}
+
+/* Ripple effect on click */
+.audio-btn::after {
+  content: '';
+  position: absolute;
+  inset: 0;
+  border-radius: 14px;
+  background: radial-gradient(circle at center, rgba(255, 200, 60, 0.25) 0%, transparent 70%);
+  opacity: 0;
+  transition: opacity 0.3s;
+}
+
+.audio-btn:active::after {
+  opacity: 1;
+}
+
+/* SVG Icons */
+.audio-icon {
+  width: 22px;
+  height: 22px;
+  flex-shrink: 0;
+  filter: drop-shadow(0 0 4px rgba(255, 220, 120, 0.3));
+  transition: filter 0.2s;
+}
+
+.audio-btn:hover .audio-icon {
+  filter: drop-shadow(0 0 8px rgba(255, 200, 60, 0.6));
+}
+
+.audio-icon.hidden {
+  display: none;
+}
+
+/* --- Mute Button States --- */
+.mute-btn {
+  border-color: rgba(0, 200, 255, 0.25);
+}
+
+.mute-btn:hover {
+  border-color: rgba(0, 230, 255, 0.45);
+  box-shadow:
+    0 8px 32px rgba(0, 0, 0, 0.5),
+    0 0 20px rgba(0, 200, 255, 0.2);
+}
+
+/* Khi muted: viß╗ün ─æß╗Å, glow ─æß╗Å */
+.mute-btn.muted {
+  border-color: rgba(255, 60, 60, 0.5);
+  background: rgba(30, 10, 10, 0.82);
+  box-shadow:
+    0 4px 20px rgba(0, 0, 0, 0.4),
+    0 0 12px rgba(255, 50, 50, 0.2),
+    inset 0 1px 0 rgba(255, 80, 80, 0.1);
+}
+
+.mute-btn.muted:hover {
+  box-shadow:
+    0 8px 32px rgba(0, 0, 0, 0.5),
+    0 0 24px rgba(255, 60, 60, 0.35);
+}
+
+/* Ring pulse indicator khi ─æang ph├ít */
+.mute-ring-indicator {
+  position: absolute;
+  inset: -3px;
+  border-radius: 16px;
+  border: 2px solid rgba(0, 200, 255, 0.4);
+  animation: audio-ring-pulse 2.5s ease-in-out infinite;
