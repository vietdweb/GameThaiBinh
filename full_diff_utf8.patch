+.history-list-header {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  font-family: var(--font-heading);
+  font-size: 11px;
+  font-weight: 700;
+  color: rgba(180, 200, 240, 0.8);
+  letter-spacing: 1px;
+  margin-top: 4px;
+}
+.list-icon {
+  width: 16px;
+  height: 16px;
+  color: #a040ff;
+}
+
+/* Track List Container */
+.history-track-list {
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+
+/* Match Item Card */
+.match-card {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 12px 14px;
+  background: rgba(255, 255, 255, 0.03);
+  border: 1px solid rgba(255, 255, 255, 0.07);
+  border-radius: 14px;
+  transition: all 0.22s ease;
+}
+.match-card:hover {
+  background: rgba(255, 255, 255, 0.06);
+  border-color: rgba(255, 255, 255, 0.15);
+  transform: translateX(2px);
+}
+.match-card.is-new-record {
+  background: linear-gradient(135deg, rgba(245, 158, 11, 0.12) 0%, rgba(255, 255, 255, 0.04) 100%);
+  border-color: rgba(245, 158, 11, 0.35);
+}
+
+.match-left {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+}
+.match-char-avatar {
+  width: 36px;
+  height: 36px;
+  border-radius: 10px;
+  background: rgba(160, 60, 255, 0.15);
+  border: 1px solid rgba(160, 60, 255, 0.3);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  font-size: 18px;
+  flex-shrink: 0;
+}
+.match-details {
+  display: flex;
+  flex-direction: column;
+}
+.match-date {
+  font-size: 11px;
+  color: rgba(200, 210, 240, 0.7);
+  font-family: var(--font-body);
+}
+.match-char-name {
+  font-size: 12px;
+  font-weight: 700;
+  color: #fff;
+}
+
+.match-center {
+  display: flex;
+  flex-direction: column;
+  align-items: flex-end;
+}
+.match-score {
+  font-family: var(--font-number, 'Rajdhani', sans-serif);
+  font-size: 18px;
+  font-weight: 800;
+  color: #00e5ff;
+  line-height: 1.1;
+}
+.match-card.is-new-record .match-score {
+  color: #ffd700;
+  text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
+}
+.match-meta-row {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  font-size: 11px;
+  color: rgba(200, 200, 240, 0.7);
+}
+
+.match-right {
+  display: flex;
+  align-items: center;
+}
+.match-badge {
+  font-size: 10px;
+  font-weight: 700;
+  padding: 4px 8px;
+  border-radius: 8px;
+  letter-spacing: 0.5px;
+  white-space: nowrap;
+}
+.badge-gold {
+  background: rgba(245, 158, 11, 0.2);
+  border: 1px solid rgba(245, 158, 11, 0.5);
+  color: #fbbf24;
+}
+.badge-silver {
+  background: rgba(160, 60, 255, 0.2);
+  border: 1px solid rgba(160, 60, 255, 0.5);
+  color: #c084fc;
+}
+.badge-coins {
+  background: rgba(0, 229, 255, 0.18);
+  border: 1px solid rgba(0, 229, 255, 0.4);
+  color: #38bdf8;
+}
+.badge-normal {
+  background: rgba(255, 255, 255, 0.08);
+  border: 1px solid rgba(255, 255, 255, 0.12);
+  color: rgba(200, 210, 240, 0.7);
+}
+
+/* History Footer */
+.history-footer {
+  padding: 12px 18px;
+  border-top: 1px solid rgba(255, 255, 255, 0.06);
+  background: rgba(0, 0, 0, 0.2);
+  display: flex;
+  justify-content: flex-end;
+  flex-shrink: 0;
+}
+.btn-clear-history {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  padding: 8px 14px;
+  border-radius: 10px;
+  border: 1px solid rgba(255, 60, 60, 0.3);
+  background: rgba(255, 60, 60, 0.1);
+  color: #ff6060;
+  font-family: var(--font-body);
+  font-size: 12px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: all 0.2s ease;
+}
+.btn-clear-history:hover {
+  background: rgba(255, 60, 60, 0.25);
+  border-color: rgba(255, 60, 60, 0.6);
+  color: #fff;
+  transform: translateY(-1px);
+}
+.trash-icon {
+  width: 14px;
+  height: 14px;
+}
+
+/* Empty History State */
+.history-empty-state {
+  padding: 30px 20px;
+  text-align: center;
+  color: rgba(200, 210, 240, 0.5);
+  font-size: 13px;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 10px;
+}
+.empty-icon {
+  width: 36px;
+  height: 36px;
+  color: rgba(200, 210, 240, 0.3);
+}
+
+/* ================================================================
+   TOP BAR CURRENCY HUD (Mobile AAA Resource Bar)
+   ================================================================ */
+.top-currency-bar {
+  position: fixed;
+  top: 18px;
+  left: 50%;
+  transform: translateX(-50%);
+  z-index: 9999;
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  pointer-events: auto !important;
+  opacity: 1;
+  visibility: visible;
+  transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
+}
+
+.top-currency-bar.visible-in-menu {
+  opacity: 1 !important;
+  visibility: visible !important;
+  pointer-events: auto !important;
+  display: flex !important;
+}
+
+/* Resource Pill (Vi├¬n nang t├ái nguy├¬n) */
+.resource-pill {
+  position: relative;
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  background: rgba(10, 14, 28, 0.78);
+  backdrop-filter: blur(20px);
+  -webkit-backdrop-filter: blur(20px);
+  border: 1px solid rgba(255, 255, 255, 0.18);
+  border-radius: 24px;
+  padding: 4px 6px 4px 10px;
+  box-shadow:
+    0 8px 24px rgba(0, 0, 0, 0.5),
+    inset 0 1px 0 rgba(255, 255, 255, 0.12);
+  transition: transform 0.2s ease, border-color 0.2s ease;
+}
+.resource-pill:hover {
+  border-color: rgba(255, 255, 255, 0.35);
+  transform: translateY(-1px);
+}
+
+/* Specific Pill Color Accents */
+.pill-meat {
+  border-color: rgba(255, 120, 80, 0.35);
+}
+.pill-coins {
+  border-color: rgba(245, 158, 11, 0.35);
+}
+.pill-gems {
+  border-color: rgba(0, 229, 255, 0.35);
+}
+
+.pill-icon-wrap {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+}
+.pill-emoji {
+  font-size: 18px;
+  filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.4));
+}
+
+.pill-val-wrap {
+  display: flex;
+  align-items: center;
+  min-width: 44px;
+}
+.pill-val {
+  font-family: var(--font-number, 'Rajdhani', sans-serif);
+  font-size: 16px;
+  font-weight: 800;
+  color: #fff;
+  letter-spacing: 0.8px;
+}
+.pill-meat .pill-val { color: #ff8a65; }
+.pill-coins .pill-val { color: #ffd700; }
+.pill-gems .pill-val { color: #00e5ff; }
+
+/* Pop Scale Animation */
+.pill-val.pop-scale {
+  animation: pop-scale-anim 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
+}
+@keyframes pop-scale-anim {
+  0% { transform: scale(1); }
+  50% { transform: scale(1.35); color: #fff; }
+  100% { transform: scale(1); }
+}
+
+/* Quick Buy / Add Button (+) */
+.btn-pill-add {
+  width: 22px;
+  height: 22px;
+  border-radius: 50%;
+  border: 1px solid rgba(255, 255, 255, 0.3);
+  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
+  color: #fff;
+  font-family: var(--font-heading);
+  font-size: 14px;
+  font-weight: 800;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  cursor: pointer;
+  box-shadow: 0 0 8px rgba(16, 185, 129, 0.5);
+  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
+  margin-left: 2px;
+}
+.btn-pill-add:hover {
+  transform: scale(1.18);
+  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
+  box-shadow: 0 0 14px rgba(52, 211, 153, 0.8);
+}
+.btn-pill-add:active {
+  transform: scale(0.9);
+}
+
+/* ================================================================
+   INSUFFICIENT MEAT ALERT MODAL
+   ================================================================ */
+.meat-alert-modal {
+  position: fixed;
+  inset: 0;
+  z-index: 999;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  padding: 16px;
+  pointer-events: none;
+  opacity: 0;
+  visibility: hidden;
+  transition: opacity 0.3s ease, visibility 0.3s ease;
+}
+.meat-alert-modal.open {
+  opacity: 1;
+  visibility: visible;
+  pointer-events: auto;
+}
+
+.meat-alert-backdrop {
+  position: absolute;
+  inset: 0;
+  background: rgba(0, 0, 0, 0.65);
+  backdrop-filter: blur(10px);
+  -webkit-backdrop-filter: blur(10px);
+}
+
+.meat-alert-card {
+  position: relative;
+  width: min(360px, 90vw);
+  background: rgba(14, 18, 36, 0.96);
+  backdrop-filter: blur(24px);
+  border: 1px solid rgba(255, 120, 80, 0.4);
+  border-radius: 24px;
+  padding: 24px 20px;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  text-align: center;
+  box-shadow:
+    0 24px 80px rgba(0, 0, 0, 0.85),
+    0 0 30px rgba(255, 120, 80, 0.25);
+  transform: scale(0.9);
+  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
+}
+.meat-alert-modal.open .meat-alert-card {
+  transform: scale(1);
+}
+
+.alert-icon-wrap {
+  font-size: 48px;
+  margin-bottom: 8px;
+  filter: drop-shadow(0 0 16px rgba(255, 120, 80, 0.6));
+  animation: float-meat 2s ease-in-out infinite alternate;
+}
+@keyframes float-meat {
+  from { transform: translateY(0); }
+  to { transform: translateY(-6px); }
+}
+
+.alert-title {
+  font-family: var(--font-heading);
+  font-size: 15px;
+  font-weight: 800;
+  color: #ff8a65;
+  letter-spacing: 1px;
+  margin: 0 0 8px;
+}
+
+.alert-message {
+  font-size: 13px;
+  color: rgba(220, 230, 250, 0.85);
+  font-family: var(--font-body);
+  margin: 0 0 20px;
+  line-height: 1.4;
+}
+
+.alert-actions {
+  display: flex;
+  flex-direction: column;
+  gap: 10px;
+  width: 100%;
+}
+
+.btn-alert-fill {
+  width: 100%;
+  height: 44px;
+  border-radius: 14px;
+  border: 1px solid rgba(16, 185, 129, 0.6);
+  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
+  color: #fff;
+  font-family: var(--font-heading);
+  font-size: 14px;
+  font-weight: 800;
+  cursor: pointer;
+  box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
+  transition: all 0.2s ease;
+}
+.btn-alert-fill:hover {
+  transform: translateY(-2px);
+  box-shadow: 0 8px 24px rgba(16, 185, 129, 0.6);
+}
+
+.btn-alert-close {
+  width: 100%;
+  height: 38px;
+  border-radius: 12px;
+  border: 1px solid rgba(255, 255, 255, 0.12);
+  background: rgba(255, 255, 255, 0.06);
+  color: rgba(200, 210, 240, 0.8);
+  font-family: var(--font-body);
+  font-size: 13px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: all 0.2s ease;
+}
+.btn-alert-close:hover {
+  background: rgba(255, 255, 255, 0.12);
+  color: #fff;
+}
